{
  "permissions": {
    "allowBash": true,
    "allowWrite": true,
    "allowRead": true,
    "allowEdit": true,
    "allowAgent": true
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {"type": "command", "command": "echo 'Preparing environment...'"},
          {"type": "command", "command": "pip install -r requirements.txt"}
        ]
      }
    ]
  },
  "env": {
    "FLASK_ENV": "development",
    "FLASK_DEBUG": "1"
  },
  "model": "claude-3-5-sonnet-20241022",
  "temperature": 0.3
}